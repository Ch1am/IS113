<!DOCTYPE html>
<html lang="en">
<head>
    <title>Kpop Stars</title>
</head>
<body>
    <br><br> 
    <table border="1">
        <tr>
            <th>Photo</th>
            <th>Name</th>
            <th>Gender</th>
            <th>Headline</th>
            <th>Edit Link</th>
        </tr>
        <% stars.forEach(function(star) { %>
            <tr>
                <td><img src="/images/<%= star.photo %>" width="100" height="100"></td>
                <td><%= star.name %></td>
                <td><%= star.gender %></td>
                <td><%= star.headline %></td>
                <td><a href="/edit-star?id=<%= star.id %>">Edit</a></td>
            </tr>
        <% }); %>
    </table>
    <% if (!stars || stars.length === 0) { %>
        <p>Star not found</p>
    <% } %>
</body>
</html>