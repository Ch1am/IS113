<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>

    <% if( userName == undefined || errors.length > 0) { 
        
        if (errors.length > 0) {
    %> 
            <h2> <%= errors.join(', ') %> </h2>
    <%
        }
        
    %>
    <h1>Bubbly Bliss Order Form</h1>
    <p>Please select your bubble tea and customise your order.</p>

    <form action="/order" method="get">
      <!-- Customer Information -->
      <h3>Customer Information</h3>
      <label for="name">Username:</label><br />
      <input type="text" id="user" name="user" /><br />

      <label for="email">Email:</label><br />
     
      <input type="email" id="email" name="email" value="<%= email==undefined ? '' : email %>" required /><br />
      <hr />

      <!-- Bubble Tea Selection -->
      <h3>Bubble Tea Selection</h3>

      <p>Select your tea base:</p>
      <select name="tea">
        <option value="">-- Please choose --</option>
        <option value="milk-tea" <%= tea=='milk-tea' ? 'selected' : '' %> >Classic Milk Tea</option>
        <option value="green-tea" <%= tea=='green-tea' ? 'selected' : '' %>  >Green Tea</option>
        <option value="oolong-tea" <%= tea=='oolong-tea' ? 'selected' : '' %> >Oolong Tea</option>
        <option value="matcha" <%= tea=='matcha' ? 'selected' : '' %> >Matcha Latte</option>
      </select>
      <br />

      <p>Choose sugar level:</p>
      <input type="radio" id="sugar0" name="sugar" value="0%" />
      <label for="sugar0">0%</label><br />

      <input type="radio" id="sugar50" name="sugar" value="50%" />
      <label for="sugar50">50%</label><br />

      <input type="radio" id="sugar100" name="sugar" value="100%" />
      <label for="sugar100">100%</label><br />

      <p>Choose ice level:</p>
      <input type="range" name="ice" min="0" max="100" step="25" />
      <br />

      <hr />
      <!-- Toppings -->
      <h3>Toppings</h3>
      <p>Select your toppings:</p>
      <input type="checkbox" id="pearls" name="toppings" value="pearls" />
      <label for="pearls">Pearls</label><br />

      <input type="checkbox" id="grass-jelly" name="toppings" value="grass-jelly"/>
      <label for="grass-jelly">Grass Jelly</label><br />

      <input type="checkbox" id="pudding" name="toppings" value="pudding" />
      <label for="pudding">Pudding</label><br />

      <input type="checkbox" id="cheese-foam" name="toppings" value="cheese-foam"/>
      <label for="cheese-foam">Cheese Foam</label><br />
      <hr />

      <!-- Additional Notes -->
      <h3>Additional Requests</h3>
      <label for="notes">Special instructions:</label><br />
      <textarea
        id="notes"
        name="notes"
        rows="4"
        cols="40"
        placeholder="E.g. less ice, extra pearls..."
      ></textarea>
      <br><hr>

      <!-- Agreement -->
      <input type="checkbox" id="agree" name="agree" />
      <label for="agree">I confirm my order details are correct</label>

      <br /><br />

      <!-- Buttons -->
      <button type="submit">Place Order</button>
      <button type="reset">Reset</button>
    </form>

<!-- -------------------------------------------->
 <% } else { %>
    <h1>Here is your order </h1>

    <table border="1">
        <thead>
            <tr>
                <th>Name</th>
                <td> <%= userName %> </td>
            </tr>
            <tr>
                <th>Email</th>
                <td> <%= email %> </td>
            </tr>

        </thead>
    </table>

    <a href="/order.html">Go back to Order</a>

<% } %>
</body>
</html>