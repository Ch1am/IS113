                                <%}%><% }); %>
                            <%}%>
                        <% }); %></td>
                    <td><% selected.forEach(t=> { %>
                            <% if (t.slots.Thursday && t.slots.Thursday.length > 0) { %>
                                <% t.slots.Thursday.forEach(x=> { %>
                                    <% if (x == times[2]) { %>
                                    <label><input type="radio" name=`${<%= t.courseCode %>}3slots` value="<%= x%>" /><%= t.courseCode %></label><br>
                                <%}%><% }); %>
                            <%}%>
                        <% }); %></td>
                </tr>

                <!-- Friday -->
                <tr>
                    <td><%= days[4] %></td>
                    <td>
                    <% selected.forEach(t=> { %>
                            <% if (t.slots.Friday && t.slots.Friday.length > 0) { %>
